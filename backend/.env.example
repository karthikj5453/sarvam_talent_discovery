# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/sarvam_talent

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Sarvam AI ───────────────────────────────────────────────
# Get your key at https://sarvam.ai
SARVAM_API_KEY=sk_your_key_here
SARVAM_BASE_URL=https://api.sarvam.ai

# ─── Gemini LLM ──────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── AWS S3 (for audio + resume storage in production) ───────
# Leave blank to use local disk storage (dev mode)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=sarvam-talent-audio
AWS_REGION=ap-south-1

# ─── Local Storage (dev fallback when AWS creds are absent) ───
LOCAL_STORAGE_PATH=./local_audio

# ─── Evaluation Mode ─────────────────────────────────────────
# false = run evaluation inline after /screening/complete (dev)
# true  = queue Celery background task (requires Redis + worker)
ASYNC_EVAL=false

# ─── App ─────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]
